<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>

    <!-- ============================================================ -->
    <!-- Early startup                                                -->
    <!-- ============================================================ -->
    <extension point="org.eclipse.ui.startup">
        <startup class="com.architeezy.archi.connector.EarlyStartup" />
    </extension>

    <!-- ============================================================ -->
    <!-- Commands                                                     -->
    <!-- ============================================================ -->
    <extension point="org.eclipse.ui.commands">
        <command
            categoryId="org.eclipse.ui.category.file"
            id="com.architeezy.archi.connector.command.importWizard"
            name="%importWizard.label">
        </command>
        <command
            categoryId="org.eclipse.ui.category.file"
            id="com.architeezy.archi.connector.command.exportWizard"
            name="%exportWizard.label">
        </command>
        <command
            categoryId="org.eclipse.ui.category.file"
            id="com.architeezy.archi.connector.command.pullModel"
            name="%pullModel.label">
        </command>
    </extension>

    <!-- ============================================================ -->
    <!-- Handlers                                                     -->
    <!-- ============================================================ -->
    <extension point="org.eclipse.ui.handlers">
        <handler
            class="com.architeezy.archi.connector.handlers.ImportFromArchiteezyMenuHandler"
            commandId="com.architeezy.archi.connector.command.importWizard">
        </handler>
        <handler
            class="com.architeezy.archi.connector.handlers.ExportToArchiteezyMenuHandler"
            commandId="com.architeezy.archi.connector.command.exportWizard">
        </handler>
        <handler
            class="com.architeezy.archi.connector.handlers.PullFromArchiteezyHandler"
            commandId="com.architeezy.archi.connector.command.pullModel">
        </handler>
    </extension>

    <!-- ============================================================ -->
    <!-- Menu contributions                                           -->
    <!-- ============================================================ -->
    <extension point="org.eclipse.ui.menus">
        <!-- File > Import menu -->
        <menuContribution
            allPopups="false"
            locationURI="menu:import_menu?before=import_ext">
            <command
                commandId="com.architeezy.archi.connector.command.importWizard"
                id="com.architeezy.archi.connector.importMenu"
                label="%importWizard.label"
                style="push">
            </command>
        </menuContribution>

        <!-- File > Export menu -->
        <menuContribution
            allPopups="false"
            locationURI="menu:export_menu?before=export_ext">
            <command
                commandId="com.architeezy.archi.connector.command.exportWizard"
                id="com.architeezy.archi.connector.exportMenu"
                label="%exportWizard.label"
                style="push">
            </command>
        </menuContribution>

        <!-- Main toolbar – Pull button -->
        <menuContribution
            allPopups="false"
            locationURI="toolbar:org.eclipse.ui.main.toolbar">
            <toolbar
                id="com.architeezy.archi.connector.toolbar"
                label="%toolbar.label">
                <command
                    commandId="com.architeezy.archi.connector.command.pullModel"
                    icon="platform:/plugin/org.eclipse.ui/icons/full/etool16/import_wiz.png"
                    disabledIcon="platform:/plugin/org.eclipse.ui/icons/full/dtool16/import_wiz.png"
                    label="%pullModel.label"
                    tooltip="%pullModel.tooltip"
                    style="push">
                </command>
            </toolbar>
        </menuContribution>
    </extension>

</plugin>
